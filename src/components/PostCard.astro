---

<a href={`/blog/${slug}`} class="block no-underline text-inherit rounded-[12px] overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.1)] transition-transform duration-200 hover:-translate-y-[5px]">
  <article itemscope itemtype="https://schema.org/BlogPosting">
    <img src={image} alt={title}loading="lazy"decoding="async"onerror="this.src='/images/default-blog.jpg'" class="w-full h-[200px] object-cover"/>

    <div class="p-4">
      <h2 class="headline text-[20px]">{title}</h2>
      <p class="description text-[14px] text-gray-600">{description}</p>

      <!--
      {formattedDate && (
        <time class="text-[12px] text-gray-500" datetime={formattedDate.iso}itemprop="datePublished">
          {formattedDate.formatted}
        </time>
      )} -->
      
      <meta itemprop="url" content={`https://securitycars.com/blog/${slug}`} />
    </div>
  </article>
</a>