const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER;

const getWhatsappLink = (title: string) => {
  const text = encodeURIComponent(
    `Hola 👋, estoy interesado en el producto de ${title}. ¿Podrían brindarme más información y precio?`
  );

  return `https://wa.me/${whatsappNumber}?text=${text}`;
};
---

<Layout title="Productos | Security Cars"
        keywords = "luces led, focos led, luces led para autos, focos led para auto, focos led para carro, luz led para carro, focos para carro, led para autos alta y baja, focos led auto, focos led para automovil, luces hid, hid, iluminacion hid, luces hid para carro, faros hid para autos, insonorizante, insonorizacion, insonorizante para auto, aislante acustico coche, insonorizante automotriz, aislante acustico para auto, insonorizacion automovil, insonorizacion de auto, insonorización para autos, camaras de retroceso, camara de reversa para auto, camara de retroceso para autos, camara retroceso, camara retroceso auto, pantalla para carro con camara de reversa, cámara de retroceso para auto con pantalla, cámara de reversa para carro con sensores, pantalla con camara de reversa, camara para carro de reversa, camara de retroceso con pantalla, camara de retroceso con sensor, camara de retroceso con sensor para auto">
        <main>
    <div class="min-h-screen bg-white">
      {/* Services Grid */}
      <main class="py-12 px-4 md:px-8">
        <div class="max-w-7xl mx-auto">
          <header class="text-center mb-10">
            <p class="text-4xl font-bold">Nuestros Productos</p>
            <p class="text-gray-600 mt-2">
              Equipamiento y tecnología para mejorar tu vehículo
            </p>
            <span class="text-[9px] text-gray-400">Ofrecemos tanto la venta y/o instalcion del equipo</span>
          </header>





          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {services.map((service) => (
              <article class="group cursor-pointer overflow-hidden rounded-xl shadow-md hover:shadow-lg transition-all duration-300 bg-white" data-id={service.id}>
                <figure class="relative h-48 overflow-hidden">
                  <img src={service.image} alt={service.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"/>
                </figure>
                <header class="p-6 text-center w-full">
                  <h2 class="font-bold text-lg text-black">{service.title}</h2>
                </header>
              </article>
            ))}
            
            
            <a href="/servicios/insonorizacion"  rel="noopener noreferrer">
              <article class="group cursor-pointer overflow-hidden rounded-xl shadow-md hover:shadow-lg transition-all duration-300 bg-white">
                <figure class="relative h-48 overflow-hidden">
                  <img src='/insonorizante.webp' alt="g" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"/>
                </figure>
                <header class="p-6 text-center w-full">
                  <h2 class="font-bold text-lg text-black">Insonorizante</h2>
                </header>
              </article>
            </a>
        </div>
        </div>



      </main>

      {/* Modal */}
        <div id="modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-3 bg-black/50 backdrop-blur-sm">
          <div class="bg-white rounded-xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
            <div class="p-6 border-b">
              <div class="flex justify-between items-start">
                  <h1 id="modal-title" class="text-xl font-bold text-gray-900"></h1>
                <button id="close-modal" class="p-2 cursor-pointer rounded-full hover:bg-gray-100 transition-colors" aria-label="Cerrar">
                  <X className="text-gray-500" size={24} />
                </button>
              </div>
            </div>
            <div class="p-2">
              <figure class="mb-6">
                <img id="modal-img" class="w-full h-64 object-contain rounded-lg"/>
              </figure>
              <p id="modal-desc" class="text-black leading-relaxed p-2 mb-6"></p>

              <div>
                <ul id="modal-list" class="list-disc pl-6 text-black"></ul>
              </div>
              <a id="modal-whatsapp" target="_blank" rel="noopener noreferrer" class="block w-full bg-green-500 hover:bg-green-600 text-white font-medium rounded-lg transition-colors text-center py-3">Contactar ahora</a>
            </div>
          </div>
        </div>
    </div>
    </main>
  </Layout>


<script is:inline define:vars={{ services }}>
  // Elementos del DOM
  const modal = document.getElementById('modal');
  const modalTitle = document.getElementById('modal-title');
  const modalImg = document.getElementById('modal-img');
  const modalDesc = document.getElementById('modal-desc');
  const modalList = document.getElementById('modal-list');
  const modalWhatsapp = document.getElementById('modal-whatsapp');
  const closeBtn = document.getElementById('close-modal');

  // Abre el modal con la información del servicio
  function abrirModal(id) {
    const service = services.find(s => s.id === parseInt(id));
    
    if (!service) return;

    // Llenar datos del modal
    modalTitle.textContent = service.title;
    modalImg.src = service.image;
    modalDesc.textContent = service.description;
    
    // Llenar lista de características
    modalList.innerHTML = service.list
      .map(item => `<li class="mb-2"><b>${item.title}</b> <span>${item.text}</span></li>`)
      .join('');

    // Configurar link de WhatsApp (sin variable de entorno)
    const whatsappNumber = '51934567890'; // Cambiar por tu número real
    const mensaje = `Hola 👋, estoy interesado en el producto de ${service.title}`;
    modalWhatsapp.href = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(mensaje)}`;

    // Mostrar modal
    modal.classList.remove('hidden');
  }

  // Cierra el modal
  function cerrarModal() {
    modal.classList.add('hidden');
  }

  // Event listeners para abrir modal
  document.querySelectorAll('[data-id]').forEach(card => {
    card.addEventListener('click', () => {
      abrirModal(card.dataset.id);
    });
  });

  // Event listeners para cerrar modal
  closeBtn.addEventListener('click', cerrarModal);

  modal.addEventListener('click', (e) => {
    if (e.target === modal) {
      cerrarModal();
    }
  });
</script>