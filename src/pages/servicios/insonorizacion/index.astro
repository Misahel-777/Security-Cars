    description: "Tratamiento térmico de techo",
  },
];

const testimonials = [
  {
    rating: 5,
    quote:
      "El cambio en mi Mazda fue increíble. Ahora mi música suena como en un estudio y el ruido de la Javier Prado ya no me estresa.",
    name: "Ricardo M.",
    details: "San Borja | Mazda CX-5",
  },
  {
    rating: 5,
    quote:
      "Excelente trato y materiales. El calor en el habitáculo bajó muchísimo, se nota la diferencia apenas entras al auto después de dejarlo al sol.",
    name: "Carla V.",
    details: "La Molina | Toyota Prado",
  },
  {
    rating: 5,
    quote:
      "Muy profesional. El desarme fue impecable, no quedó ni un solo ruido de plásticos. Vale cada sol la inversión.",
    name: "Luis F.",
    details: "Surco | Honda Civic",
  },
