const faqs = [
  {
    question: "¿Cuánto tiempo demora el proceso?",
    answer:
      "Depende del paquete. Un tratamiento de puertas toma 4-5 horas. Un tratamiento full habitáculo demora entre 2 a 3 días hábiles.",
  },
  {
    question: "¿Afecta la garantía de mi auto nuevo?",
    answer:
      "No. No realizamos cortes de cables ni modificaciones estructurales. Nuestros materiales son inertes y el proceso es 100% reversible si se requiere.",
  },
  {
    question: "¿Añade mucho peso al vehículo?",
    answer:
      "Un tratamiento completo añade entre 25 a 40kg, equivalente a llevar un niño pequeño o medio tanque de gasolina. No afecta el consumo de combustible de forma perceptible.",
  },
  {
    question: "¿Los materiales tienen olor?",
    answer:
      "No. Usamos materiales certificados sin derivados de asfalto. No emiten olores ni gases, incluso bajo exposición directa al sol de Lima.",
  },
];

const seo = {
  title: "Insonorización de Autos en Lima | Security Cars La Molina",
  description: "Insonorizamos tu auto en La Molina: sin ruidos, sin calor, sin vibraciones. Trabajo impecable, precios económicos. Escríbenos por WhatsApp.",
  image: "og-insonorizante.webp",
  alt:"Insonorización profesional de autos en Lima",
  url: "https://securitycars.com/insonorizacion",
  ogTitle: "Tu auto puede sonar diferente — Insonorización en Lima",
  ogDescription: "Security Cars instala insonorizante profesional en La Molina. Sin ruidos, sin vibraciones, sin calor. Precios económicos y trabajo garantizado.",
